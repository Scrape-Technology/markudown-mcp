{
  "name": "markudown-mcp",
  "version": "1.0.0",
  "description": "MCP server for MarkUDown — connect AI agents to web scraping, search, and extraction",
  "type": "module",
  "bin": {
    "markudown-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "release": "bash scripts/release.sh"
  },
  "files": ["dist/", "README.md"],
  "keywords": ["mcp", "scraping", "web-scraping", "markdown", "ai", "claude", "playwright"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": { "node": ">=20.0.0" }
}
